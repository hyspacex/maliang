{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "sourceHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "entities": {
      "maxItems": 24,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entityId": {
            "type": "string",
            "maxLength": 80,
            "pattern": "^[a-z][a-z0-9_-]*:[a-z0-9][a-z0-9_-]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "character",
              "animal",
              "object",
              "place",
              "group"
            ]
          },
          "label": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "maxLength": 240
              },
              "evidence": {
                "type": "object",
                "properties": {
                  "start": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "end": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "text": {
                    "type": "string"
                  }
                },
                "required": [
                  "start",
                  "end",
                  "text"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "value",
              "evidence"
            ],
            "additionalProperties": false
          },
          "attributes": {
            "maxItems": 24,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slot": {
                  "type": "string",
                  "enum": [
                    "relative_size",
                    "color",
                    "material",
                    "texture",
                    "body_feature",
                    "clothing",
                    "identity_object",
                    "pose",
                    "facial_expression",
                    "gaze",
                    "movement",
                    "held_object",
                    "relative_position",
                    "shape"
                  ]
                },
                "value": {
                  "type": "string",
                  "maxLength": 240
                },
                "scope": {
                  "type": "string",
                  "enum": [
                    "identity_from_here",
                    "panel_state"
                  ]
                },
                "evidence": {
                  "type": "object",
                  "properties": {
                    "start": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "end": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "text": {
                      "type": "string"
                    }
